APP_NAME=Recruitment Automation API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?
DATABASE_URL=sqlite+aiosqlite:///./recruitment.db
FRONTEND_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://localhost:8000
LOCAL_UPLOAD_DIR=uploads

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Supabase storage for JD, resumes, and profile photos
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JD_BUCKET=job-descriptions
SUPABASE_APPLICATION_BUCKET=candidate-applications
LOG_LEVEL=INFO

# SMTP Configuration for email notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_SENDER_EMAIL=your-email@gmail.com
SMTP_SENDER_PASSWORD=your-app-specific-password
CANDIDATE_PORTAL_URL=http://localhost:5173

# Seeded HR user on first startup:
# Email: hr@company.com
# Password: hr123
